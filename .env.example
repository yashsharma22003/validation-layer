# ── Network ──────────────────────────────────────────────────────────────────
# RPC URL for the EVM network the registries are deployed on
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# ── Router wallet ─────────────────────────────────────────────────────────────
# EOA private key used by the Router to call validationResponse().
# This address MUST be the validatorAddress used in validationRequest().
ROUTER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── ERC-8004 Contract addresses ───────────────────────────────────────────────
# Sepolia / Base Sepolia (same address on all testnets)
IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
VALIDATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# ── Response storage ─────────────────────────────────────────────────────────
# Where to store response JSON. Options: "local" (default) | "ipfs"
RESPONSE_STORE=local
# Local storage path (relative to project root)
RESPONSE_STORE_PATH=./responses
# IPFS API (only used when RESPONSE_STORE=ipfs)
# IPFS_API_URL=https://api.pinata.cloud/pinning/pinJSONToIPFS
# IPFS_API_KEY=your_pinata_api_key

# ── Trust API server ──────────────────────────────────────────────────────────
PORT=3000

# ── Sybil resistance ──────────────────────────────────────────────────────────
# Max validation requests a single agent can submit per window
SYBIL_MAX_REQUESTS_PER_WINDOW=10
# Window duration in seconds
SYBIL_WINDOW_SECONDS=3600
# Minimum age of agent NFT (in blocks) before it may be scored
SYBIL_MIN_AGENT_AGE_BLOCKS=100
